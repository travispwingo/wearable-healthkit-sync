# Copy to `.dev.vars` for local `wrangler dev`. NEVER commit `.dev.vars`.
# In production, the deploy button prompts for these (or set them in the
# Cloudflare dashboard → Settings → Variables and Secrets).

# The ONE required secret: it gates the /setup wizard. Choose any strong value.
# (This is the only field the "Deploy to Cloudflare" button prompts for.)
SETUP_PASSWORD=choose-a-strong-password

# ---- Advanced / optional ----
# SpO2 representation is a plain var with a default in wrangler.toml ([vars]):
#   SPO2_AS_FRACTION = "true"  → HealthKit-native fraction (0.96)
#   set "false" if on-device testing shows the Shortcut wants the raw percent (96)
# Everything below is normally configured in the /setup wizard (stored in KV).
# You only need these if you prefer to skip the wizard and set Oura creds as
# secrets directly. KV values (from the wizard) take precedence; these are used
# only when the KV values are absent.
# OURA_CLIENT_ID=your_oura_client_id
# OURA_CLIENT_SECRET=your_oura_client_secret
# APP_SHARED_SECRET=fixed_sync_token_instead_of_the_generated_one

# Optional: point at the Oura sandbox for local testing without a real ring.
# OURA_API_BASE=https://api.ouraring.com
