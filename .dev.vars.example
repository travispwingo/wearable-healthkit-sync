# Copy to `.dev.vars` for local `wrangler dev`. NEVER commit `.dev.vars`.
# In production these are set with `wrangler secret put <NAME>`.

# From your Oura OAuth app at https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID=your_oura_client_id
OURA_CLIENT_SECRET=your_oura_client_secret

# Must EXACTLY match a redirect URI registered on the Oura app.
# Local dev default (wrangler dev serves on :8787):
OURA_REDIRECT_URI=http://localhost:8787/auth/callback

# Long random string the iOS Shortcut sends as `Authorization: Bearer <this>`.
# Generate one, e.g.:  openssl rand -hex 32
APP_SHARED_SECRET=generate_a_long_random_string

# SpO2 representation. "true" (default) writes the HealthKit-native fraction (0.96);
# set "false" if on-device testing shows the Shortcut wants the raw percent (96).
SPO2_AS_FRACTION=true

# Optional: point at the Oura sandbox for local testing without a real ring.
# OURA_API_BASE=https://api.ouraring.com   (sandbox path handled per-endpoint)
